# 6bq5 ignore list
# data/kg.db is committed (sanitized snapshot — precinct6 removed) so the
# platform works after `git clone` without needing the CCC source repo.
# Only ignore the runtime WAL/SHM sidecars.
data/kg.db-shm
data/kg.db-wal
frontend/node_modules/
# frontend/dist is committed so a fresh Linux box (no node/npm) can run
# the platform with Python only. Re-build with `cd frontend && npm run build`
# only when you've modified frontend source.
__pycache__/
*.pyc
.venv/
venv/
*.log
.DS_Store
.env
.env.local
.idea/
.vscode/
